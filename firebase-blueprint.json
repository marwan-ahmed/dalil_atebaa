{
  "entities": {
    "Doctor": {
      "title": "Doctor",
      "description": "A doctor listed in the directory",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the doctor" },
        "specialty": { "type": "string", "description": "Medical specialty" },
        "address": { "type": "string", "description": "Clinic or hospital address" },
        "phone": { "type": "string", "description": "Booking phone number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Approval status" },
        "addedBy": { "type": "string", "description": "UID of the user who added this doctor" },
        "createdAt": { "type": "timestamp", "description": "When the record was created" }
      },
      "required": ["name", "specialty", "address", "phone", "status", "addedBy", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["name", "email", "role", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A user review for a doctor",
      "type": "object",
      "properties": {
        "doctorId": { "type": "string", "description": "ID of the doctor being reviewed" },
        "userId": { "type": "string", "description": "UID of the user leaving the review" },
        "userName": { "type": "string", "description": "Name of the user leaving the review" },
        "rating": { "type": "number", "description": "Rating from 1 to 5" },
        "comment": { "type": "string", "description": "Review comment text" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Review approval status" },
        "createdAt": { "type": "timestamp", "description": "When the review was created" }
      },
      "required": ["doctorId", "userId", "userName", "rating", "comment", "status", "createdAt"]
    },
    "Specialty": {
      "title": "Specialty",
      "description": "A medical specialty for doctors",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the specialty in Arabic" },
        "order": { "type": "number", "description": "Sorting order" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["name", "order", "createdAt"]
    }
  },
  "firestore": {
    "/doctors/{doctorId}": {
      "schema": { "$ref": "#/entities/Doctor" },
      "description": "Collection of doctors"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Collection of users"
    },
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Collection of doctor reviews"
    },
    "/specialties/{specialtyId}": {
      "schema": { "$ref": "#/entities/Specialty" },
      "description": "Collection of medical specialties"
    }
  }
}
